# Copy this file to `.env` and fill in your key. Only needed for the live "Ask" agent —
# the dashboard, cross-filtering, and specimen ledger all work with no key at all.

# Your Nebius Token Factory API key (https://tokenfactory.nebius.com/).
NEBIUS_API_KEY=

# Optional overrides:
# NEBIUS_MODEL=nvidia/nemotron-3-super-120b-a12b
# NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
